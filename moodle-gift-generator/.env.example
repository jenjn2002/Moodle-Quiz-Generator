# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=giftuser
DB_PASSWORD=giftpassword
DB_NAME=giftdb

# Session (change this to a random 32+ char string)
SESSION_SECRET=your-super-secret-session-key-change-this

# Microsoft 365 SSO
# Tạo App Registration tại: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Redirect URI: http://localhost:8080/auth/callback
MS365_CLIENT_ID=your-azure-app-client-id
MS365_CLIENT_SECRET=your-azure-app-client-secret
MS365_TENANT_ID=your-azure-tenant-id
MS365_REDIRECT_URL=http://localhost:8080/auth/callback

# Anthropic API Key (lấy tại https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# App URL
APP_BASE_URL=http://localhost:8080
PORT=8080
